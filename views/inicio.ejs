<!DOCTYPE html>
<html lang="pt-BR">
<head>
  <meta charset="UTF-8">
  <title>Fraternitas - início</title>
  <link rel="stylesheet" href="/css/style.css">
</head>
<body>
<% if (usuario) { %>
<div id="header">
  <div id="header-inner">
    <a href="/inicio" id="logo">Fraternitas</a>
    <form action="/buscar" method="GET" id="search-form">
      <input type="text" name="q" placeholder="buscar pessoas..." autocomplete="off">
      <button type="submit">buscar</button>
    </form>
    <nav>
      <a href="/inicio">início</a>
      <a href="/perfil">meu perfil</a>
      <a href="/amigos">amigos</a>
      <a href="/comunidades">comunidades</a>
      <a href="/sair">sair</a>
    </nav>
  </div>
</div>
<% } %>
<div id="page">
<div class="layout3col">
  <div>
    <div class="panel">
      <div class="avatar-box">
        <div class="avatar-circle"><%= usuario.nome.split(' ').map(function(n){return n[0]}).join('').slice(0,2).toUpperCase() %></div>
        <div class="user-name-big"><%= usuario.nome %></div>
        <div class="user-location"><%= usuario.cidade ? usuario.cidade + (usuario.estado ? ', ' + usuario.estado : '') : 'Brasil' %></div>
      </div>
      <ul class="stat-list">
        <li><span>amigos</span><a href="/amigos">ver todos</a></li>
        <li><span>comunidades</span><a href="/comunidades">ver todas</a></li>
        <li><span>perfil</span><a href="/perfil">editar</a></li>
      </ul>
    </div>
    <div class="panel">
      <div class="panel-header">navegação</div>
      <ul class="side-menu">
        <li><a href="/inicio">🏠 início</a></li>
        <li><a href="/perfil">👤 meu perfil</a></li>
        <li><a href="/amigos">👥 amigos</a></li>
        <li><a href="/comunidades">💬 comunidades</a></li>
        <li><a href="/buscar">🔍 buscar pessoas</a></li>
      </ul>
    </div>
  </div>

  <div>
    <% if (solicitacoes.length > 0) { %>
    <div class="panel">
      <div class="panel-header">⚠️ solicitações de amizade (<%= solicitacoes.length %>)</div>
      <div class="panel-body">
        <% solicitacoes.forEach(function(s) { %>
        <div class="solicitacao-item">
          <span><a href="/perfil/<%= s.uid %>"><%= s.nome %></a> quer ser seu amigo</span>
          <div style="display:flex;gap:4px;">
            <form method="POST" action="/amigo/aceitar" style="display:inline">
              <input type="hidden" name="amizade_id" value="<%= s.id %>">
              <button class="btn btn-primary" type="submit">aceitar</button>
            </form>
            <form method="POST" action="/amigo/recusar" style="display:inline">
              <input type="hidden" name="amizade_id" value="<%= s.id %>">
              <button class="btn btn-secondary" type="submit">recusar</button>
            </form>
          </div>
        </div>
        <% }) %>
      </div>
    </div>
    <% } %>

    <div class="panel">
      <div class="panel-header">últimos scraps recebidos</div>
      <div class="panel-body">
        <% if (scrapsRecentes.length === 0) { %>
          <p style="font-size:12px;color:#888;">nenhum scrap ainda. <a href="/buscar">adicione amigos!</a></p>
        <% } else { %>
          <% scrapsRecentes.forEach(function(s) { %>
          <div class="scrap-item">
            <a href="/perfil/<%= s.de_user_id %>" class="scrap-from"><%= s.de_nome %></a>
            <span class="scrap-date"><%= new Date(s.created_at).toLocaleDateString('pt-BR') %></span>
            <div class="scrap-text"><%= s.texto %></div>
          </div>
          <% }) %>
        <% } %>
        <div style="margin-top:8px;">
          <a href="/perfil" class="btn btn-secondary">ver todos os scraps</a>
        </div>
      </div>
    </div>
  </div>

  <div>
    <div class="panel">
      <div class="panel-header">meus amigos</div>
      <div class="panel-body">
        <% if (amigos.length === 0) { %>
          <p style="font-size:11px;color:#888;">nenhum amigo ainda!</p>
        <% } else { %>
          <div class="friend-grid">
          <% amigos.slice(0,6).forEach(function(a) { %>
            <div class="friend-item">
              <a href="/perfil/<%= a.id %>">
                <div class="friend-avatar" style="background:#4a90d4;"><%= a.nome.split(' ').map(function(n){return n[0]}).join('').slice(0,2).toUpperCase() %></div>
                <div class="friend-name"><%= a.nome.split(' ')[0] %></div>
              </a>
            </div>
          <% }) %>
          </div>
        <% } %>
        <div style="margin-top:8px;"><a href="/amigos" style="font-size:11px;">ver todos</a></div>
      </div>
    </div>
    <div class="panel">
      <div class="panel-header">minhas comunidades</div>
      <div class="panel-body">
        <% if (comunidades.length === 0) { %>
          <p style="font-size:11px;color:#888;">nenhuma ainda!</p>
        <% } else { %>
          <% comunidades.forEach(function(c) { %>
          <div class="comm-item">
            <div class="comm-icon"><%= c.icone %></div>
            <div><div class="comm-name"><a href="/comunidade/<%= c.id %>"><%= c.nome %></a></div></div>
          </div>
          <% }) %>
        <% } %>
        <div style="margin-top:8px;"><a href="/comunidades" style="font-size:11px;">ver todas</a></div>
      </div>
    </div>
  </div>
</div>
</div>
<div id="footer">© 2025 Fraternitas (feito com ❤️ nostalgia)</div>
</body>
</html>
