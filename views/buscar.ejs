<!DOCTYPE html>
<html lang="pt-BR">
<head><meta charset="UTF-8"><title>Fraternitas - buscar</title><link rel="stylesheet" href="/css/style.css"></head>
<body>
<% if (usuario) { %><div id="header"><div id="header-inner"><a href="/inicio" id="logo">Fraternitas</a><form action="/buscar" method="GET" id="search-form"><input type="text" name="q" placeholder="buscar amigos..."><button type="submit">buscar</button></form><nav><a href="/inicio">início</a><a href="/perfil">meu perfil</a><a href="/amigos">amigos</a><a href="/comunidades">comunidades</a><a href="/intencoes">✝ orações</a><a href="/sair">sair</a></nav></div></div><% } %>
<div id="page">
<div style="max-width:600px;">
  <div class="panel" style="margin-bottom:10px;">
    <div class="panel-header">buscar pessoas</div>
    <div class="panel-body">
      <form action="/buscar" method="GET" style="display:flex;gap:6px;">
        <input type="text" name="q" value="<%= q %>" placeholder="nome da pessoa..." style="flex:1;padding:6px 8px;border:1px solid #aac6e0;border-radius:3px;font-size:13px;">
        <button type="submit" class="btn btn-primary">buscar</button>
      </form>
    </div>
  </div>
  <% if (q) { %>
  <div class="panel">
    <div class="panel-header">resultados para "<%= q %>" (<%= users.length %>)</div>
    <div class="panel-body">
      <% if (users.length === 0) { %>
        <p style="font-size:12px;color:#888;">nenhuma pessoa encontrada.</p>
      <% } else { users.forEach(function(u) { %>
        <div style="display:flex;align-items:center;gap:10px;padding:8px 0;border-bottom:1px solid #eef;">
          <div class="friend-avatar" style="background:#4a90d4;width:46px;height:46px;font-size:16px;flex-shrink:0;"><%= u.nome.split(' ').map(function(n){return n[0]}).join('').slice(0,2).toUpperCase() %></div>
          <div style="flex:1;">
            <div style="font-weight:bold;"><a href="/perfil/<%= u.id %>"><%= u.nome %></a></div>
            <div style="font-size:11px;color:#888;"><%= u.cidade || '' %><%= u.estado ? ', '+u.estado : '' %></div>
          </div>
          <div style="display:flex;gap:4px;">
            <a href="/perfil/<%= u.id %>" class="btn btn-secondary">ver perfil</a>
            <form method="POST" action="/amigo/adicionar" style="display:inline">
              <input type="hidden" name="amigo_id" value="<%= u.id %>">
              <button class="btn btn-primary" type="submit">+ amigo</button>
            </form>
          </div>
        </div>
      <% }) } %>
    </div>
  </div>
  <% } %>
</div>
</div>
<div id="footer">© 2025 Fraternitas</div>
</body></html>
